<link rel="stylesheet" href="/css/style.css">

<h1>Sistema de Formulários Para Cadastro de Pesquisadores</h1>

{{#if loggedIn}}
  <section>
    <h2>Seções disponíveis</h2>
    <ul>
      <li><a href="/researchers/new">Cadastro de Pesquisador</a></li>
      <li><a href="/forms/request">Nova Solicitação de Pesquisador</a></li>
      <li><a href="/researchers">Ver Cadastros de Pesquisadores</a></li>
      <li><a href="/records/request">Ver Solicitações de Pesquisadores</a></li>
    </ul>
    <p><a href="/auth/logout">Sair</a></p>
  </section>
{{else}} 
  <section>
    <h2>Faça login para acessar o sistema</h2>
    <ul>
      <li><a href="/auth/login">Login</a></li>
      <h2>Não tem uma conta? cadastre-se abaixo!</h2>
      <li><a href="/auth/register">Criar conta</a></li>
    </ul>
  </section>
{{/if}}