<!DOCTYPE html>
<html>
<head>
  <link rel="stylesheet" href="/css/style.css">
</head>
<body>

<div class="container">
  <h1>Editar Pesquisador</h1>

  <form action="/researchers/{{person.id}}/edit" method="post">

    <label>Nome:</label>
    <input type="text" name="nome" value="{{person.nome}}">

    <label>Email:</label>
    <input type="email" name="email" value="{{person.email}}">

    <label>Telefone:</label>
    <input type="text" name="telefone" value="{{person.telefone}}">

    <label>Cidade:</label>
    <input type="text" name="cidade" value="{{person.cidade}}">

    <button type="submit">Atualizar</button>
  </form>

  <br> <hr> <br>

  <a href="/researchers" class="btn-secondary">Voltar</a>

</div>

</body>
</html>
